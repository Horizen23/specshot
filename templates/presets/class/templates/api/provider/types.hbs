export * from "{{#if importAlias}}{{importAlias}}/core{{else}}{{relPath outDir coreOut}}{{/if}}/types";

export interface BackendResponse<T> {
  request_id: string;
  data: T;
}

export interface AppApiErrorData {
  $schema?: string;
  request_id?: string;
  status: number;
