{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interceptor Plugins Variables",
  "description": "Controls which interceptor plugin files are generated",
  "type": "object",
  "properties": {
    "pluginNames": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["bearer", "logger", "request-id", "circuit-breaker"]
      },
      "default": [],
      "description": "List of plugins to generate"
    },
    "toastLibrary": {
      "type": "string",
      "enum": [
        "none",
        "sonner",
        "react-toastify",
        "react-hot-toast",
        "vue-toastification",
        "sweetalert2",
        "alert"
      ],
      "default": "none",
      "description": "Select a UI library to automatically handle global API error toasts"
    }
  },
  "required": []
}
