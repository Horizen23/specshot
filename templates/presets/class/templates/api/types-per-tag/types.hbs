{{!-- ---
behavior: generated
target: {{outputDir}}
name: {{tagPrefix}}.types.ts
iterate: tags
--- --}}
// AUTO-GENERATED BY specshot
{{#ifNeq validation "types-only"}}
import { z } from "zod";
{{/ifNeq}}

{{#if imports.length}}
// -- Shared Models --
{{#each ../schemas}}
{{#if (includes ../imports name)}}
{{#ifEq ../validation "types-only"}}
export type {{name}} = {{{tsType}}};
{{else}}
export const {{name}}Schema = {{{zod}}};
export type {{name}} = z.infer<typeof {{name}}Schema>;
{{/ifEq}}
{{/if}}
{{/each}}

{{/if}}

{{#if specificSchemas.length}}
// -- Specific Models for {{tag}} --
{{#each specificSchemas}}
{{#ifEq ../validation "types-only"}}
export type {{name}} = {{{tsType}}};
{{else}}
export const {{name}}Schema = {{{zod}}};
export type {{name}} = z.infer<typeof {{name}}Schema>;
{{/ifEq}}

{{/each}}
{{/if}}

// -- Request & Response Types --
{{#each operations}}
{{#if hasBody}}
export type {{typeNamePayload}} = {{{bodyType}}};
{{/if}}

{{#if hasQuery}}
export type {{typeNameParams}} = {
{{#each queryParams}}
  {{name}}{{#unless required}}?{{/unless}}: {{{tsType}}};
{{/each}}
};
{{/if}}

{{#ifEq ../validation "types-only"}}
export type {{typeNameResponse}} = {{{resType}}};
{{else}}
export const {{typeNameResponse}}Schema = {{{resZod}}};
export type {{typeNameResponse}} = z.infer<typeof {{typeNameResponse}}Schema>;
{{/ifEq}}

{{/each}}

