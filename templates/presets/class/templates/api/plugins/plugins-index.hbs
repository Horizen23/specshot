{{!-- ---
behavior: generated
target: {{outputDir}}/../plugins
name: index.ts
--- --}}
{{#each (scanPlugins (concat outputDir "/../interceptors"))}}
import { {{this.fn}} } from "../interceptors/{{this.file}}";
{{/each}}
{{#hasFile (concat outputDir "/../interceptors/bearer-auth-manager.ts")}}
// Re-export for direct access
export { AuthManager } from "../interceptors/bearer-auth-manager";
{{/hasFile}}

// ==========================================
// Plugin Registry
// ==========================================

import type { ApiClientWithPlugins } from "../client";

type PluginInstaller = (client: ApiClientWithPlugins) => void;
const registry: PluginInstaller[] = [];
{{#each (scanPlugins (concat outputDir "/../interceptors"))}}
registry.push({{this.fn}});
{{/each}}

export function useAllPlugins(client: ApiClientWithPlugins) {
  for (const install of registry) {
    install(client);
  }
  return client;
}
