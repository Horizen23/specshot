import type { ApiClientWithPlugins } from "../client";

export function installLogger(client: ApiClientWithPlugins) {
  client.interceptors.request.use(async (config, url) => {
    console.log(`→ ${config.method?.toUpperCase() ?? "GET"} ${url}`);
    return config;
  });

  client.interceptors.response.use(async (response, url) => {
    console.log(`← ${response.status} ${url}`);
    return response;
  });
}
