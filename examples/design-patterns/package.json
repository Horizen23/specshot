{
  "name": "specshot-design-patterns",
  "private": true,
  "type": "module",
  "scripts": {
    "specshot:init": "specshot init",
    "specshot:template:list": "specshot templates list",
    "specshot:generate": "npm run specshot:generate:singleton && npm run specshot:generate:factory && npm run specshot:generate:observer && npm run specshot:generate:builder",
    "specshot:generate:singleton": "specshot generate --config specshot.singleton.config.mjs",
    "specshot:generate:factory": "specshot generate --config specshot.factory.config.mjs",
    "specshot:generate:observer": "specshot generate --config specshot.observer.config.mjs",
    "specshot:generate:builder": "specshot generate --config specshot.builder.config.mjs",
    "reset": "rm -rf src && npm run specshot:generate"
  },
  "dependencies": {
    "specshot": "file:../.."
  }
}
