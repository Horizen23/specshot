// ─────────────────────────────────────────────
// Request Builder (Builder pattern only)
// ─────────────────────────────────────────────
export interface RequestConfig {
  headers: Record<string, string>;
  timeout: number;
  retries: number;
  signal?: AbortSignal;
  cache?: boolean;
}

export class RequestBuilder<T> {
  private _url: string;
  private _method: string;
  private _body?: unknown;
  private _config: RequestConfig = {
    headers: {},
    timeout: 10000,
    retries: 0,
    cache: false,
  };

  constructor(method: string, url: string) {
    this._method = method;
    this._url = url;
  }

  body(data: unknown): this {
    this._body = data;
    return this;
  }

  header(key: string, value: string): this {
    this._config.headers[key] = value;
    return this;
  }

  auth(token: string): this {
    return this.header("Authorization", `Bearer ${token}`);
  }

  timeout(ms: number): this {
    this._config.timeout = ms;
    return this;
  }

  retries(count: number): this {
    this._config.retries = count;
    return this;
  }

  signal(sig: AbortSignal): this {
    this._config.signal = sig;
    return this;
  }

  withCache(): this {
    this._config.cache = true;
    return this;
  }

  async execute(): Promise<T> {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), this._config.timeout);

    const finalHeaders: Record<string, string> = {
      ...this._config.headers,
      ...(this._body ? { "Content-Type": "application/json" } : {}),
    };

    let lastError: Error | null = null;
    const maxAttempts = this._config.retries + 1;

    for (let attempt = 0; attempt < maxAttempts; attempt++) {
      try {
        const _res = await fetch(this._url, {
          method: this._method,
          headers: finalHeaders,
          ...(this._body ? { body: JSON.stringify(this._body) } : {}),
          signal: this._config.signal || controller.signal,
        });
        clearTimeout(timeoutId);

        if (!_res.ok) {
          const _errBody = await _res.text().catch(() => "");
          throw new ApiError(`${this._method} ${this._url} failed: ${_res.status}`, _res.status, _errBody);
        }

        if (this._method === "DELETE") return undefined as T;
        return _res.json() as Promise<T>;
      } catch (err) {
        lastError = err as Error;
        if (attempt < maxAttempts - 1) {
          await new Promise((r) => setTimeout(r, 2 ** attempt * 100));
        }
      }
    }
    clearTimeout(timeoutId);
    throw lastError || new Error("Request failed");
  }
}

