// Event Types
// ─────────────────────────────────────────────

export type {{className}}EventType = "before" | "after" | "error";

export interface {{className}}Event<T = unknown> {
  type: {{className}}EventType;
  method: string;
  url: string;
  status?: number;
  data?: T;
  error?: Error;
  timestamp: number;
  durationMs: number;
}

type Listener<T = unknown> = (event: {{className}}Event<T>) => void;

